# PostgreSQL — matches docker-compose.yml
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ragodb

# LM Studio — update URL/model to match your local setup
LM_STUDIO_URL=http://localhost:1234
LM_STUDIO_MODEL=nomic-ai/nomic-embed-text-v1.5

# Must match the dimension your embedding model outputs
# Common values: 384 (MiniLM), 768 (nomic-embed), 1536 (text-embedding-ada-002)
EMBEDDING_DIM=768
